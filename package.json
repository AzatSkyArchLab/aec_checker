{
  "name": "agr_checker",
  "version": "0.1.0",
  "description": "Модульный IFC-парсер: просмотр атрибутов объекта и 3D-превью модели",
  "type": "module",
  "scripts": {
    "postinstall": "node scripts/copy-wasm.mjs",
    "predev": "node scripts/copy-wasm.mjs",
    "prebuild": "node scripts/copy-wasm.mjs",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "ifc",
    "bim",
    "parser",
    "viewer",
    "web-ifc",
    "three"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "leaflet": "^1.9.4",
    "pdfmake": "^0.3.11",
    "proj4": "^2.20.9",
    "three": "^0.184.0",
    "web-ifc": "^0.0.77"
  },
  "devDependencies": {
    "@types/leaflet": "^1.9.21",
    "@types/pdfmake": "^0.3.3",
    "@types/proj4": "^2.5.6",
    "@types/three": "^0.184.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  }
}
